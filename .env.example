# ─── Mercer Systems — .env.example ───────────────────────────────────────────
# Copy to .env and fill in your values: cp .env.example .env
# Never commit .env — it contains private keys and API secrets.

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Solana wallet (required for live trading) ────────────────────────────────

# Helius recommended: https://helius.dev (free tier works)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Your wallet's public address (base58)
WALLET_ADDRESS=YourBase58WalletAddressHere

# Private key — two accepted formats:
#   JSON byte-array (Solana CLI): [12,34,56,...]   → cat ~/.config/solana/id.json
#   Base58 string (Phantom/Backpack): Settings → Export private key
WALLET_PRIVATE_KEY=YourBase58PrivateKeyOrJSONArrayHere

# ─── Execution ────────────────────────────────────────────────────────────────

# Set to 'false' only when ready for real on-chain trades
DRY_RUN=true

# Enable Claude's decisions to trigger execution automatically
AUTO_EXECUTE=true

# Hard cap per individual trade (USD). Scales PUMP_MAX_USD automatically.
MAX_TRADE_USD=35

# Minimum trade size — below this, skipped to avoid wasting gas (USD)
MIN_TRADE_USD=3

# Seconds that must pass between executed trades (anti-churn)
MIN_CYCLE_INTERVAL=300

# ─── Risk management ──────────────────────────────────────────────────────────

# Active risk mandate: conservative | moderate | aggressive
MERCER_MANDATE=moderate

# Minimum SOL to keep in wallet at all times for gas fees
MIN_SOL_FOR_GAS=0.01

# Minimum SOL value (USD) to preserve as gas + buffer when selling SOL
MIN_SOL_VALUE_USD=4

# Maximum acceptable Jupiter price impact % before a trade is blocked
MAX_PRICE_IMPACT_PCT=2.0

# ─── pump.fun bonding curve ───────────────────────────────────────────────────

# Hard cap per pump.fun buy (USD). If not set, auto-derives as 30% of MAX_TRADE_USD.
# Example: MAX_TRADE_USD=35 → PUMP_MAX_USD=10.50 automatically.
# Set explicitly to override the auto-scaling.
# PUMP_MAX_USD=10

# ─── Notifications ────────────────────────────────────────────────────────────

# Discord webhook for trade alerts and stop-loss notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Market data ──────────────────────────────────────────────────────────────

# CoinGecko demo key (free at coingecko.com/en/api) — recommended for better rate limits
# COINGECKO_API_KEY=CG-...

# ─── Advanced (optional) ──────────────────────────────────────────────────────

# API server port
PORT=3000

# Watchdog check interval in milliseconds
# WATCHDOG_INTERVAL_MS=30000

# 1h price drop % threshold for momentum alerts (positive number)
# ALERT_1H_DROP_PCT=5.0

# Dashboard data refresh interval in milliseconds
# DATA_REFRESH_MS=60000
